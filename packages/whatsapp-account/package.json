{
  "name": "@officemap/whatsapp-account",
  "version": "0.1.0",
  "description": "WhatsApp Business account management components for OfficeMap: embedded signup onboarding, WABA, and phone number management.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch & tsc-alias -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "axios": "^1.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "axios": "^1.7.0",
    "jsdom": "^29.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.7",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.6.1",
    "tailwind-merge": "^3.4.0"
  }
}
